<%# Reusable Devise password input with a show/hide eye toggle.
    Locals:
      f             - form builder
      attr          - :password or :password_confirmation
      label         - display label
      autocomplete  - "current-password" | "new-password"
      autofocus     - true / false (default false)
%>
<div class="flex flex-col" data-controller="password-toggle">
  <label class="text-xs uppercase tracking-widest text-muted mb-1"><%= label %></label>
  <div class="relative">
    <%= f.password_field attr,
          autofocus: local_assigns.fetch(:autofocus, false),
          autocomplete: autocomplete,
          data: { password_toggle_target: "input" },
          class: "w-full bg-cream/5 border border-border rounded-lg px-4 py-3 pr-11 text-cream font-sans text-sm outline-none focus:border-pk transition-colors" %>
    <button type="button"
            data-action="click->password-toggle#toggle"
            aria-label="Toggle password visibility"
            class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 text-muted hover:text-cream transition-colors cursor-pointer bg-transparent border-none">
      <%# Eye open — shown when password is hidden (default) %>
      <svg data-password-toggle-target="iconShow"
           class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      <%# Eye with slash — shown when password is visible %>
      <svg data-password-toggle-target="iconHide"
           class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
        <line x1="1" y1="1" x2="23" y2="23"/>
      </svg>
    </button>
  </div>
</div>
