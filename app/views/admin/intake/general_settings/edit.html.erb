<h1 class="text-2xl font-medium mb-2">General Settings</h1>
<p class="text-sm text-gray-500 mb-6">Master on/off switch for the chatbot and the auto-reply users hear when it's paused.</p>

<%= form_with model: @setting, url: admin_intake_general_settings_path, method: :patch, scope: :setting, local: true, class: "bg-white rounded-xl border border-gray-200 p-6 max-w-2xl space-y-5" do |f| %>
  <div>
    <label class="text-[0.65rem] uppercase tracking-wider text-gray-500">Global mode</label>
    <%= f.select :global_mode, [ [ "AI on (chatbot responds normally)", "ai" ], [ "Paused (auto-reply only)", "paused" ] ], {}, class: "w-full mt-1 border border-gray-300 rounded-lg px-3 py-2 text-sm" %>
    <p class="text-xs text-gray-500 mt-1">When paused, incoming messages are stored but get the auto-reply below instead of an AI response.</p>
  </div>

  <div>
    <label class="text-[0.65rem] uppercase tracking-wider text-gray-500">Generic paused auto-reply</label>
    <%= f.text_area :paused_auto_reply, class: "w-full mt-1 border border-gray-300 rounded-lg px-3 py-2 text-sm", rows: 3 %>
    <p class="text-xs text-gray-500 mt-1">Fallback message when no specific reply is set on the chatbot config (paused_reply / quiet_hours_reply).</p>
  </div>

  <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
    <%= f.submit "Save general settings", class: "px-5 py-2 bg-pk text-white rounded-lg text-sm hover:bg-pk-dk transition-colors cursor-pointer border-none" %>
  </div>
<% end %>
