<div class="mb-6">
  <%= link_to "← All Intake Conversations", admin_intake_conversations_path, class: "text-sm text-gray-500 hover:text-gray-900 no-underline" %>
</div>

<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-lg font-medium font-mono"><%= mask_phone(@conversation.whatsapp_number) %></h1>
    <p class="text-xs text-gray-500 mt-1">
      <%= intake_status_badge(@conversation.status) %>
      <%= intake_mode_pill(@conversation.mode) %>
      <% if @conversation.intake_complete %>
        <span class="ml-2 text-green-700">✓ Intake complete</span>
      <% end %>
    </p>
  </div>
  <div class="flex items-center gap-2">
    <% if @conversation.mode == "human" %>
      <%= button_to "Release to AI", release_admin_intake_conversation_path(@conversation), method: :post,
            class: "px-4 py-2 bg-white border border-gray-200 rounded-lg text-xs text-gray-700 hover:border-pk hover:text-pk transition-colors cursor-pointer font-inherit" %>
    <% else %>
      <%= button_to "Take Over", take_over_admin_intake_conversation_path(@conversation), method: :post,
            class: "px-4 py-2 bg-pk text-white rounded-lg text-xs hover:bg-pk-dk transition-colors cursor-pointer border-none font-inherit" %>
    <% end %>
    <% unless @conversation.status == "completed" %>
      <%= button_to "Mark Complete", mark_complete_admin_intake_conversation_path(@conversation), method: :post,
            class: "px-4 py-2 bg-white border border-gray-200 rounded-lg text-xs text-gray-700 hover:border-green-500 hover:text-green-700 transition-colors cursor-pointer font-inherit" %>
    <% end %>
    <% unless @conversation.status == "abandoned" %>
      <%= button_to "Mark Abandoned", mark_abandoned_admin_intake_conversation_path(@conversation), method: :post,
            class: "px-4 py-2 bg-white border border-gray-200 rounded-lg text-xs text-gray-700 hover:border-gray-500 hover:text-gray-700 transition-colors cursor-pointer font-inherit",
            data: { turbo_confirm: "Mark this conversation as abandoned?" } %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# Chat thread (tight CRM transcript) %>
  <div class="lg:col-span-2 bg-white rounded-xl border border-gray-200 overflow-hidden">
    <%= turbo_stream_from @conversation %>
    <div id="intake_messages" class="py-2 flex flex-col divide-y divide-gray-100 min-h-[400px] max-h-[600px] overflow-y-auto" data-controller="scroll-bottom">
      <% if @messages.empty? %>
        <p class="text-sm text-gray-400 text-center py-12">No messages yet.</p>
      <% else %>
        <%= render partial: "admin/intake/messages/message", collection: @messages, as: :message %>
        <div class="px-3 pt-3 pb-4">
          <%= render partial: "admin/intake/conversations/intake_summary_frame", locals: { conversation: @conversation } %>
        </div>
      <% end %>
    </div>

    <% if @conversation.mode == "human" %>
      <div class="px-6 py-4 border-t border-gray-200 bg-blue-50">
        <%= form_with url: admin_intake_conversation_messages_path(@conversation), local: true, class: "flex items-center gap-3" do |f| %>
          <%= f.text_field "message[content]",
                placeholder: "Type your reply (sent via WhatsApp)…",
                autocomplete: "off",
                class: "flex-1 border border-gray-300 rounded-full px-5 py-2.5 text-sm outline-none focus:border-pk transition-colors" %>
          <%= f.submit "Send", class: "px-4 py-2 bg-pk text-white rounded-full text-xs hover:bg-pk-dk transition-colors cursor-pointer border-none" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Extracted lead sidebar (live-updates via Turbo on intake completion) %>
  <%= render "admin/intake/conversations/sidebar", conversation: @conversation %>
</div>
