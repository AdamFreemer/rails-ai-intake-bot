<div class="flex items-center justify-between mb-8">
  <h1 class="font-serif text-2xl">Intake Conversations</h1>

  <details class="relative group" data-controller="dismissible-details" data-action="toggle->dismissible-details#enforceSingleOpen">
    <summary class="cursor-pointer list-none flex items-center gap-2 px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs text-gray-700 hover:border-pk transition-colors select-none">
      <span class="flex items-center -space-x-0.5">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-green-500"></span>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-pk/60"></span>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-blue-400"></span>
      </span>
      <span>Platform:</span>
      <span class="font-medium text-gray-900">All</span>
      <svg class="w-3 h-3 text-gray-400 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
    </summary>

    <div class="absolute right-0 mt-2 w-72 bg-white border border-gray-200 rounded-lg shadow-lg z-10 overflow-hidden">
      <div class="px-4 py-2.5 bg-pk/5 border-b border-pk/15 flex items-center gap-2">
        <svg class="w-3.5 h-3.5 text-pk" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span class="text-sm font-medium text-gray-900">All Platforms</span>
        <span class="ml-auto text-[0.6rem] uppercase tracking-wider text-pk font-semibold">Selected</span>
      </div>

      <div class="py-1">
        <div class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700">
          <span class="inline-block w-2 h-2 rounded-full bg-green-500"></span>
          <span>WhatsApp</span>
          <span class="ml-auto text-[0.6rem] uppercase tracking-wider text-green-700 font-semibold">Active</span>
        </div>
        <% [ "Instagram DM", "Facebook Messenger", "SMS", "Web Chat Widget", "Telegram" ].each do |channel| %>
          <div class="flex items-center gap-2 px-4 py-2 text-sm text-gray-400 cursor-not-allowed">
            <span class="inline-block w-2 h-2 rounded-full bg-gray-300"></span>
            <span><%= channel %></span>
            <span class="ml-auto text-[0.6rem] uppercase tracking-wider text-gray-400">Coming soon</span>
          </div>
        <% end %>
      </div>

      <div class="px-4 py-3 bg-gray-50 border-t border-gray-100">
        <p class="text-[0.7rem] text-gray-500 leading-relaxed">Built to scale across every channel your clients reach out on. New platforms light up as you grow.</p>
      </div>
    </div>
  </details>
</div>

<%= form_with url: admin_intake_conversations_path, method: :get,
      data: {
        controller: "debounced-form",
        action: "input->debounced-form#submit change->debounced-form#submitNow",
        turbo_frame: "intake_conversations_results"
      },
      class: "flex flex-wrap items-end gap-3 mb-6" do |f| %>
  <%# Preserve current sort across search/filter changes %>
  <%= f.hidden_field :sort, value: params[:sort] if params[:sort].present? %>
  <%= f.hidden_field :dir,  value: params[:dir]  if params[:dir].present?  %>
  <div class="flex flex-col">
    <label class="text-[0.65rem] uppercase tracking-wider text-gray-500 mb-1">Search</label>
    <%= f.text_field :q, value: params[:q], placeholder: "Phone, name, message text…", autocomplete: "off", class: "border border-gray-300 rounded-lg px-3 py-1.5 text-sm w-72 focus:outline-none focus:border-pk transition-colors" %>
  </div>
  <div class="flex flex-col">
    <label class="text-[0.65rem] uppercase tracking-wider text-gray-500 mb-1">Status</label>
    <%= f.select :status, options_for_select([ [ "All", "" ], [ "Active", "active" ], [ "Completed", "completed" ], [ "Abandoned", "abandoned" ] ], params[:status]), {}, class: "border border-gray-300 rounded-lg px-3 py-1.5 text-sm" %>
  </div>
  <div class="flex flex-col">
    <label class="text-[0.65rem] uppercase tracking-wider text-gray-500 mb-1">Mode</label>
    <%= f.select :mode, options_for_select([ [ "All", "" ], [ "AI", "ai" ], [ "Human", "human" ], [ "Paused", "paused" ] ], params[:mode]), {}, class: "border border-gray-300 rounded-lg px-3 py-1.5 text-sm" %>
  </div>
  <% if params[:q].present? || params[:status].present? || params[:mode].present? %>
    <%= link_to "Reset", admin_intake_conversations_path, class: "text-xs text-gray-500 hover:text-gray-700 no-underline self-center", data: { turbo_frame: "_top" } %>
  <% end %>
<% end %>

<%= turbo_frame_tag "intake_conversations_results" do %>
  <% if @conversations.any? %>
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-[0.65rem] uppercase tracking-wider text-gray-500">
          <tr>
            <%= sortable_header :lead_name,    "Name",         frame: "intake_conversations_results" %>
            <%= sortable_header :phone,        "Phone",        frame: "intake_conversations_results" %>
            <th class="text-left px-6 py-3">Preview</th>
            <%= sortable_header :status,       "Status",       frame: "intake_conversations_results" %>
            <%= sortable_header :mode,         "Mode",         frame: "intake_conversations_results" %>
            <%= sortable_header :last_message, "Last Message", frame: "intake_conversations_results" %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @conversations.each do |c| %>
            <% last = c.messages.last %>
            <tr class="hover:bg-gray-50 cursor-pointer" data-turbo-frame="_top" onclick="window.location='<%= admin_intake_conversation_path(c) %>'">
              <td class="px-6 py-3 text-sm font-medium text-gray-900">
                <% if c.lead %>
                  <%= c.lead.full_name.presence || c.lead.first_name %>
                <% else %>
                  <span class="text-gray-300 italic font-normal">in progress</span>
                <% end %>
              </td>
              <td class="px-6 py-3 font-mono text-xs text-gray-700"><%= mask_phone(c.whatsapp_number) %></td>
              <td class="px-6 py-3 text-gray-600 max-w-md truncate"><%= last&.content&.truncate(80) %></td>
              <td class="px-6 py-3">
                <%= intake_status_badge(c.status) %>
              </td>
              <td class="px-6 py-3">
                <%= intake_mode_pill(c.mode) %>
              </td>
              <td class="px-6 py-3 text-xs text-gray-400">
                <%= c.last_message_at ? time_ago_in_words(c.last_message_at) + " ago" : "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-gray-200 p-12 text-center text-sm text-gray-400">
      No conversations match those filters.
    </div>
  <% end %>
<% end %>
