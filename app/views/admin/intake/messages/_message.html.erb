<%# Business / CRM transcript row — all messages flush-left, distinguished by
    a colored role label + subtle background tint. Inline timestamp on the right. %>
<% case message.role
   when "user"
     role_label  = "USER"
     role_class  = "bg-gray-100 text-gray-600"
     row_bg      = "hover:bg-gray-50"
   when "assistant"
     role_label  = "AI"
     role_class  = "bg-pk/10 text-pk"
     row_bg      = "hover:bg-pk/[0.02]"
   when "admin"
     role_label  = "ADMIN"
     role_class  = "bg-blue-100 text-blue-700"
     row_bg      = "hover:bg-blue-50/40"
   else
     role_label  = message.role.upcase
     role_class  = "bg-gray-100 text-gray-600"
     row_bg      = "hover:bg-gray-50"
   end %>

<%= tag.div id: dom_id(message),
            class: "group flex items-start gap-3 px-3 py-2 #{row_bg} transition-colors" do %>
  <span class="inline-flex items-center justify-center px-1.5 py-0.5 rounded text-[0.55rem] font-semibold tracking-wider flex-shrink-0 mt-0.5 <%= role_class %>" style="min-width: 3rem;">
    <%= role_label %>
  </span>
  <p class="text-[0.82rem] text-gray-800 leading-snug whitespace-pre-line flex-1 mt-0.5"><%= message.content %></p>
  <span class="text-[0.6rem] text-gray-400 flex-shrink-0 mt-1 opacity-0 group-hover:opacity-100 transition-opacity">
    <%= message.created_at.strftime("%-I:%M %p") %>
  </span>
<% end %>
